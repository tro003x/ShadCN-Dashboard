# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Private keys and certificates
*.key
*.p12
*.pfx
*.crt

# IDE credentials
.idea/
*.suo
*.user

# Sensitive config files
secrets.json
**/secrets/

# npm/yarn tokens
.npmrc

# Database files
*.sqlite
*.db

# AWS/Cloud credentials
.aws/
.gcloud/
